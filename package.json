{
  "name": "@thinkliveid/n8n-nodes-waswuz",
  "version": "1.1.8",
  "description": "n8n community node for Waswuz - Send WhatsApp, Instagram & Messenger messages with interactive buttons, flexible customer lookup, and typing indicators",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "waswuz",
    "whatsapp",
    "instagram",
    "messenger",
    "facebook",
    "messaging",
    "chat",
    "automation"
  ],
  "license": "MIT",
  "homepage": "https://waswuz.com",
  "author": {
    "name": "Waswuz",
    "email": "support@waswuz.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thinkliveid/n8n-nodes-waswuz.git"
  },
  "main": "dist/nodes/WaswuzPlatform/WaswuzPlatform.node.js",
  "scripts": {
    "build": "tsc && npm run copy-icons",
    "copy-icons": "node -e \"const fs=require('fs'); fs.cpSync('nodes/WaswuzPlatform/icon.svg', 'dist/nodes/WaswuzPlatform/icon.svg', {force:true}); fs.cpSync('nodes/WaswuzWebhook/icon.svg', 'dist/nodes/WaswuzWebhook/icon.svg', {force:true}); fs.cpSync('nodes/OpenClawWebhook/icon.svg', 'dist/nodes/OpenClawWebhook/icon.svg', {force:true});\"",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials config --write",
    "lint": "eslint nodes credentials config package.json",
    "test": "npm run build && node --test test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/WaswuzPlatformApi.credentials.js",
      "dist/credentials/OpenClawWebhookAuth.credentials.js"
    ],
    "nodes": [
      "dist/nodes/WaswuzPlatform/WaswuzPlatform.node.js",
      "dist/nodes/WaswuzWebhook/WaswuzWebhook.node.js",
      "dist/nodes/OpenClawWebhook/OpenClawWebhook.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^7.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.0.0",
    "n8n-workflow": "^1.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^25.5.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
